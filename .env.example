# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Supercell Developer API Keys
# Get from: https://developer.brawlstars.com/
BS_API_KEY=your_brawlstars_api_key

# Get from: https://developer.clashroyale.com/
CR_API_KEY=your_clashroyale_api_key

# Get from: https://developer.clashofclans.com/
COC_API_KEY=your_clashofclans_api_key

# SQLite database file path
DATABASE_PATH=bot.db
